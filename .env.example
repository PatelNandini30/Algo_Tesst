# AlgoTest Environment Configuration
# Copy this file to .env and update values as needed

# ===================
# Database
# ===================
DATABASE_URL=postgresql://algotest:algotest_password@postgres:5432/algotest

# ===================
# Redis
# ===================
REDIS_URL=redis://redis:6379/0

# ===================
# Application
# ===================
# Set to 'true' to use PostgreSQL instead of CSV files
# Keep 'false' until migration is complete
USE_POSTGRESQL=false

# Data directory (mount CSV volumes here in Docker)
DATA_DIR=/data

# ===================
# Python
# ===================
PYTHONUNBUFFERED=1

# ===================
# Frontend (for development)
# ===================
VITE_API_URL=http://localhost:8000
