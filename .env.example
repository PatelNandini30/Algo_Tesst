# AlgoTest Environment Configuration
# Copy this file to .env and update values as needed

# ===================
# Database
# ===================
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=algotest
POSTGRES_USER=algotest
POSTGRES_PASSWORD=algotest_password
# Optional: override the assembled connection string with a single URL
DATABASE_URL=postgresql://algotest:algotest_password@postgres:5432/algotest
ALLOW_CSV_FALLBACK=true

# ===================
# Redis
# ===================
REDIS_URL=redis://redis:6379/0

# ===================
# Application
# ===================
# PostgreSQL is the primary data source. Set to 'false' to force CSV fallback temporarily.
USE_POSTGRESQL=true

# Data directory (mount CSV volumes here in Docker if DataSource falls back)
DATA_DIR=/data

# ===================
# Python
# ===================
PYTHONUNBUFFERED=1

# ===================
# Frontend (for development)
# ===================
VITE_API_URL=http://localhost:8000
